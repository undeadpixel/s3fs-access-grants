root = true


[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,markdown}]
indent_size = 1
trim_trailing_whitespace = true

[*.{yml,yaml,json,toml,js,mjs,cjs,ts}]
indent_size = 2

[Makefile]
indent_style = tab
